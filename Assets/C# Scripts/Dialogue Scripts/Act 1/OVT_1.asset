  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 786c7bc14905c2f45b560b57ac49e2c3, type: 3}
  m_Name: OVT_1
  m_EditorClassIdentifier: 
  keepPanelOpenAtEnd: 1
  lines:
  - characterName: MINION
    lineText: "Ava\u2026 tunggu sebentar!"
    commands: []
  - characterName: AVA
    lineText: Tidak, aku hanya perlu menyusun tugas yang pas dan tidak berat untukku.
    commands:
    - type: 1
      value: 
      audioAsset: {fileID: 0}
      spriteAsset: {fileID: 21300000, guid: 93d40e3a07f297444827a05118da7db5, type: 3}
  - characterName: MINION
    lineText: Ava, perhatikan. Tadi ada coretan kertas kuning.
    commands: []
  - characterName: MINION
    lineText: Bukankah itu berarti kamu telah mencapai batasmu?
    commands: []
  - characterName: AVA
    lineText: Cuma sebentar lagi, Minion. Aku ingin mencobanya lagi.
    commands:
    - type: 1
      value: 
      audioAsset: {fileID: 0}
      spriteAsset: {fileID: 21300000, guid: 9bf943f71623c264885804e87a446f0f, type: 3}
  - characterName: MINION
    lineText: Mungkin sesekali kamu perlu alihkan dari tugas-tugas itu, Ava.
    commands: []
