  m_Script: {fileID: 11500000, guid: 786c7bc14905c2f45b560b57ac49e2c3, type: 3}
  m_Name: PC_Puzzle1
  m_EditorClassIdentifier: 
  keepPanelOpenAtEnd: 0
  lines:
  - characterName: AVA
    lineText: "Dulu, tangan ini terasa begitu besar\u2026"
    commands:
    - type: 1
      value: 
      audioAsset: {fileID: 0}
      spriteAsset: {fileID: 21300000, guid: 9bf943f71623c264885804e87a446f0f, type: 3}
  - characterName: AVA
    lineText: "\u2026 seolah sanggup melindungiku dari apa pun"
    commands: []
  - characterName: MINION
    lineText: Tangan yang sama yang selalu menuntunmu saat kamu takut melangkah
    commands: []
  - characterName: AVA
    lineText: Sekarang tanganku sudah besar, tapi aku justru merasa tersesat
    commands:
    - type: 1
      value: 
      audioAsset: {fileID: 0}
      spriteAsset: {fileID: 21300000, guid: f28c52487a794dc42a6e477e87e5fa96, type: 3}
  - characterName: AVA
    lineText: Aku rindu rasa aman saat berjalan...
    commands: []
  - characterName: AVA
    lineText: tanpa harus tahu arahnya ke mana
    commands: []
  - characterName: MINION
    lineText: "Dulu kamu masih hanya anak kecil\u2026"
    commands: []
  - characterName: MINION
    lineText: dan dewasa membuatmu merasa harus berusaha menentukan arah itu sendiri
    commands: []
  - characterName: AVA
    lineText: Sejujurnya, aku hanya ingin tetap ditemani
    commands:
    - type: 1
      value: 
      audioAsset: {fileID: 0}
      spriteAsset: {fileID: 21300000, guid: 9bf943f71623c264885804e87a446f0f, type: 3}
