%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 786c7bc14905c2f45b560b57ac49e2c3, type: 3}
  m_Name: PC_Puzzle5
  m_EditorClassIdentifier: 
  keepPanelOpenAtEnd: 0
  lines:
  - characterName: AVA
    lineText: "Aku ingat luka karena jatuh dari sepeda ini\u2026"
    commands:
    - type: 1
      value: 
      audioAsset: {fileID: 0}
      spriteAsset: {fileID: 21300000, guid: 5009ad2fa8a51074991cdd49ad87d1ad, type: 3}
  - characterName: AVA
    lineText: "Aku menangis, rasanya perih sekali\u2026"
    commands: []
  - characterName: MINION
    lineText: Tapi waktu itu kamu nggak berhenti mencoba lagi, kan?
    commands: []
  - characterName: MINION
    lineText: Kamu cuma nangis sebentar, lalu naik lagi
    commands: []
  - characterName: AVA
    lineText: "Dulu... jatuh ternyata nggak semenakutkan itu ya\u2026"
    commands:
    - type: 2
      value: 
      audioAsset: {fileID: 0}
      spriteAsset: {fileID: 21300000, guid: 9bf943f71623c264885804e87a446f0f, type: 3}
  - characterName: AVA
    lineText: Kenapa sekarang aku jadi penakut banget, ya?
    commands: []
  - characterName: AVA
    lineText: Aku mudah takut dengan kegagalan dan ketidakpastian
    commands: []
  - characterName: MINION
    lineText: Bagaimana kalau melalui kedua hal itu sebenarnya membuka banyak kesempatan
      di masa depan?
    commands: []
  - characterName: AVA
    lineText: Kesempatan?
    commands: []
  - characterName: AVA
    lineText: Ah iya, kesempatan memberikan harapan baru!
    commands: []
